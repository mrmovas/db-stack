{
    "name": "db-stack",
    "version": "1.0.0",
    "description": "Standalone database stack with Docker, Kysely migrations, backup, restore, and cron scheduling.",
    "main": "dist/src/index.js",
    "scripts": {
        "build": "tsc && tsc-alias",
        "start": "node dist/src/index.js",
        "typecheck": "tsc --noEmit",
        "biome:format": "npx @biomejs/biome check --write ./src",
        "biome:lint": "npx @biomejs/biome lint --write ./src",
        "biome:check": "npx @biomejs/biome check ./src",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "@biomejs/biome": "2.4.12",
        "@types/node": "^25.6.0",
        "@types/node-cron": "^3.0.11",
        "@types/pg": "^8.20.0",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2"
    },
    "dependencies": {
        "commander": "^14.0.3",
        "dotenv": "^17.4.2",
        "kysely": "^0.28.16",
        "node-cron": "^4.2.1",
        "pg": "^8.20.0",
        "zod": "^4.3.6"
    }
}
